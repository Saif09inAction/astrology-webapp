rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── LEADS: anyone can create, only logged-in admin can read/update/delete
    match /leads/{leadId} {
      allow create: if true;
      allow read, update, delete: if request.auth != null;
    }

    // ── SERVICES: anyone can read (for website), only admin can write
    match /services/{docId} {
      allow read: if true;
      allow create, update, delete: if request.auth != null;
    }

    // ── TESTIMONIALS: anyone can read, only admin can write
    match /testimonials/{docId} {
      allow read: if true;
      allow create, update, delete: if request.auth != null;
    }

    // ── SETTINGS: anyone can read (website loads settings), only admin can write
    match /settings/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
