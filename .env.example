# ── Meta Pixel (client — safe to expose in browser) ──
VITE_META_PIXEL_ID=your_pixel_id_here

# Set to "true" to log pixel/CAPI events in browser console (dev only)
VITE_META_DEBUG=false

# ── Meta Conversion API (server-only — set in Vercel, NEVER commit) ──
META_PIXEL_ID=your_pixel_id_here
META_CONVERSION_API_TOKEN=your_capi_access_token_here

# Optional: Meta Events Manager → Test Events code (remove in production)
# META_TEST_EVENT_CODE=TEST12345
